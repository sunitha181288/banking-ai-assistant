# ═══════════════════════════════════════════════
# NexaBank AI — .gitignore
# What this file does:
# Tells Git which files to NEVER upload to GitHub.
# Three main reasons to ignore files:
# 1. SECRETS     — API keys, passwords (security risk)
# 2. GENERATED   — files built from your code (wasteful)
# 3. LOCAL ONLY  — your personal editor/OS files (noise)
# ═══════════════════════════════════════════════


# ── 1. SECRETS — NEVER commit these ─────────────
# Your .env file contains real API keys.
# If this goes to GitHub, anyone can steal your keys
# and run up charges on your Anthropic/Pinecone account.
.env
.env.local
.env.development
.env.production
.env.staging
*.pem
*.key
*.cert
*.p12
secrets/


# ── 2. PYTHON (Backend) ──────────────────────────

# Virtual environment — installed packages
# (100s of MBs, everyone reinstalls via: pip install -r requirements.txt)
venv/
.venv/
env/
ENV/

# Python bytecode — auto-generated when Python runs your code
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
wheels/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/

# Type checker
.mypy_cache/
.dmypy.json

# SQLite database — auto-created by our dev fallback
# This is a local data file, not code — don't commit it
*.db
*.sqlite
*.sqlite3
nexabank.db

# Jupyter notebooks
.ipynb_checkpoints/


# ── 3. NODE / NEXT.JS (Frontend) ─────────────────

# node_modules — installed packages
# (often 500MB+, everyone reinstalls via: npm install)
node_modules/
.pnp
.pnp.js

# Next.js build output — generated by: npm run build
.next/
out/

# Vercel deployment (auto-generated on deploy)
.vercel

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm
.yarn-integrity

# TypeScript
*.tsbuildinfo
next-env.d.ts


# ── 4. DOCKER ────────────────────────────────────

# Local override — dev-specific settings not for the team
docker-compose.override.yml


# ── 5. OPERATING SYSTEM ──────────────────────────

# macOS — Finder creates these automatically, pure noise
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# ── 6. VS CODE ───────────────────────────────────

# Personal editor preferences (not everyone uses VS Code)
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-snippets
.history/


# ── 7. OTHER EDITORS ─────────────────────────────

# JetBrains (PyCharm, WebStorm)
.idea/
*.iml

# Vim
*.swp
*.swo

# Emacs
\#*\#
.\#*


# ── 8. LOGS ──────────────────────────────────────

logs/
*.log
*.log.*


# ── 9. UPLOADS / TEMP ────────────────────────────

uploads/
tmp/
temp/
*.tmp


# ── 10. ML MODEL FILES ───────────────────────────
*.pkl
*.pickle
*.joblib
*.h5
*.pt
*.pth
*.onnx
models/

.cache/

